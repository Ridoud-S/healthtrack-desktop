<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.itc.healthtrack.controller.DoctorLayoutController"
    prefWidth="1280"
    prefHeight="780"
    stylesheets="@../css/doctor_layout.css">

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SIDEBAR IZQUIERDO — Panel de Triage               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="270" spacing="0">

            <!-- Logo / Nombre del sistema -->
            <VBox styleClass="sidebar-header" spacing="4">
                <Label text="🏥 HealthTrack" styleClass="app-logo" />
                <Label text="Estación de Telemedicina" styleClass="app-subtitle" />
            </VBox>

            <Separator styleClass="sidebar-divider" />

            <!-- Info del médico activo -->
            <VBox styleClass="doctor-info-card" spacing="2">
                <Label fx:id="lblDoctorName" text="Cargando..." styleClass="doctor-name" />
                <Label fx:id="lblDoctorId" text="ID: ---" styleClass="doctor-id" />
                <Label text="EN LÍNEA" styleClass="status-badge" />
            </VBox>

            <Separator styleClass="sidebar-divider" />

            <!-- ─── Sección: Pacientes Asignados ─── -->
            <HBox styleClass="patients-header" alignment="CENTER_LEFT" spacing="8">
                <Label text="MIS PACIENTES" styleClass="sidebar-section-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblPatientCount" text="(0)" styleClass="patient-count-badge" />
            </HBox>

            <!-- Barra de búsqueda rápida -->
            <HBox styleClass="search-bar-container">
                <TextField fx:id="txtBuscarPaciente"
                           promptText="🔍 Buscar paciente..."
                           styleClass="search-field"
                           maxWidth="Infinity"
                           HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Lista scrollable de pacientes -->
            <ScrollPane styleClass="patient-list-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="pacientesContainer" styleClass="patient-list-container" spacing="4">
                    <!-- Items de pacientes se agregan dinámicamente -->
                </VBox>
            </ScrollPane>

            <Separator styleClass="sidebar-divider" />

            <!-- Botón de cerrar sesión -->
            <Button fx:id="btnLogout"
                    text="⬅  Cerrar Sesión"
                    styleClass="nav-btn, nav-btn-danger"
                    maxWidth="Infinity"
                    onAction="#handleLogout">
                <VBox.margin><Insets top="4" bottom="12" left="8" right="8" /></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  ÁREA CENTRAL — Detalle del paciente seleccionado  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <center>
        <AnchorPane fx:id="contentArea" styleClass="content-area">
            <!-- Estado vacío: se muestra cuando no hay paciente seleccionado -->
            <VBox fx:id="emptyState" styleClass="empty-state"
                  alignment="CENTER" spacing="12"
                  AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                <Label text="🩺" styleClass="empty-icon" />
                <Label text="Centro de Mando del Paciente" styleClass="empty-title" />
                <Label text="Selecciona un paciente del panel izquierdo para ver su historial clínico, tendencias y enviar prescripciones." styleClass="empty-subtitle" />
            </VBox>
        </AnchorPane>
    </center>

</BorderPane>
