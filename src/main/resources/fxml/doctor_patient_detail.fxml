<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.itc.healthtrack.controller.DoctorPatientDetailController"
            fitToWidth="true" fitToHeight="true"
            styleClass="detail-scroll-root"
            stylesheets="@../css/doctor_patient_detail.css">

    <VBox styleClass="detail-root" spacing="0">

        <!-- ═══════════════════════════════════════════════ -->
        <!--  HEADER DEL PACIENTE                            -->
        <!-- ═══════════════════════════════════════════════ -->
        <HBox styleClass="patient-header" alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="2">
                <Label fx:id="lblPatientName" text="Paciente" styleClass="header-patient-name" />
                <Label fx:id="lblPatientUid" text="UID: ---" styleClass="header-patient-uid" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblMetricCount" text="0 registros" styleClass="header-metric-count" />
        </HBox>

        <Separator styleClass="section-divider" />

        <!-- ═══════════════════════════════════════════════ -->
        <!--  TENDENCIAS — LineChart con pestañas            -->
        <!-- ═══════════════════════════════════════════════ -->
        <VBox styleClass="section-container" spacing="8">
            <Label text="📈 Tendencias del Paciente" styleClass="section-title" />

            <TabPane fx:id="tabPaneTrends" styleClass="trends-tab-pane" tabClosingPolicy="UNAVAILABLE">
                <Tab text="Presión Arterial">
                    <LineChart fx:id="chartPresion" styleClass="trend-chart">
                        <xAxis><CategoryAxis label="Fecha" side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis label="mmHg" side="LEFT" /></yAxis>
                    </LineChart>
                </Tab>
                <Tab text="Glucosa">
                    <LineChart fx:id="chartGlucosa" styleClass="trend-chart">
                        <xAxis><CategoryAxis label="Fecha" side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis label="mg/dL" side="LEFT" /></yAxis>
                    </LineChart>
                </Tab>
                <Tab text="Frec. Cardíaca">
                    <LineChart fx:id="chartFC" styleClass="trend-chart">
                        <xAxis><CategoryAxis label="Fecha" side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis label="BPM" side="LEFT" /></yAxis>
                    </LineChart>
                </Tab>
                <Tab text="Peso / IMC">
                    <LineChart fx:id="chartPeso" styleClass="trend-chart">
                        <xAxis><CategoryAxis label="Fecha" side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis label="kg / IMC" side="LEFT" /></yAxis>
                    </LineChart>
                </Tab>
            </TabPane>
        </VBox>

        <Separator styleClass="section-divider" />

        <!-- ═══════════════════════════════════════════════ -->
        <!--  PANEL INFERIOR: Historial + Prescripción       -->
        <!-- ═══════════════════════════════════════════════ -->
        <HBox styleClass="bottom-panels" spacing="16" VBox.vgrow="ALWAYS">

            <!-- ── Izquierda: Historial de métricas ──── -->
            <VBox styleClass="panel-card" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="📋 Historial de Métricas" styleClass="panel-title" />
                <TableView fx:id="tablaMetricas" styleClass="metrics-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha"        text="Fecha"         prefWidth="155" />
                        <TableColumn fx:id="colTipo"         text="Tipo"          prefWidth="130" />
                        <TableColumn fx:id="colValPrimario"  text="Val. Primario" prefWidth="100" />
                        <TableColumn fx:id="colValSecundario" text="Val. Secundario" prefWidth="110" />
                        <TableColumn fx:id="colAlerta"       text="Alerta"        prefWidth="65" />
                    </columns>
                </TableView>
            </VBox>

            <!-- ── Derecha: Panel de Prescripción ──── -->
            <VBox styleClass="panel-card, prescription-panel" spacing="12" prefWidth="380">
                <Label text="💊 Prescripción / Recomendación" styleClass="panel-title" />
                <Label text="Escribe una nota médica para el paciente:" styleClass="prescription-hint" />

                <TextArea fx:id="txtPrescripcion"
                          styleClass="prescription-textarea"
                          promptText="Ej: Continuar con Metformina 500mg cada 12h. Realizar caminata de 30 min diarios..."
                          wrapText="true"
                          VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Label fx:id="lblFeedback" text="" styleClass="feedback-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnEnviar"
                            text="📤 Enviar al Paciente"
                            styleClass="btn-send"
                            onAction="#handleEnviarNota" />
                </HBox>
            </VBox>

        </HBox>

    </VBox>

</ScrollPane>
