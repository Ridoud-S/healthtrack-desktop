<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
    Sub-módulo: Frecuencia Cardíaca
    ────────────────────────────────────────────────────────────────
    - Un solo campo de entrada (BPM).
    - Tabla filtrada a tipo FRECUENCIA_CARDIACA.
    - Sin tamaños absolutos — crece con el contentArea del Shell.
    ────────────────────────────────────────────────────────────────
-->
<AnchorPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.itc.healthtrack.controller.HeartRateController"
    stylesheets="@../css/patient_heart_rate.css">

    <VBox
        AnchorPane.topAnchor="0"
        AnchorPane.bottomAnchor="0"
        AnchorPane.leftAnchor="0"
        AnchorPane.rightAnchor="0"
        spacing="16"
        styleClass="module-root">

        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <!-- ── Header del módulo ── -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="module-header">
            <Label text="💓" styleClass="module-icon" />
            <VBox spacing="2">
                <Label text="Frecuencia Cardíaca" styleClass="module-title" />
                <Label fx:id="lblWelcome" styleClass="module-subtitle" />
            </VBox>
        </HBox>

        <Separator styleClass="module-divider" />

        <!-- ── Formulario de registro ── -->
        <VBox spacing="10" styleClass="form-card">
            <Label text="Registrar nueva medición" styleClass="section-title" />

            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Latidos por minuto (BPM)" styleClass="field-label" />
                    <TextField fx:id="txtBpm"
                               promptText="ej. 72"
                               prefWidth="200"
                               styleClass="metric-field" />
                </VBox>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnGuardarFc"
                        text="＋  Guardar métrica"
                        styleClass="btn-primary"
                        onAction="#onGuardarFcPressed"
                        defaultButton="true" />
            </HBox>

            <!-- Mensaje de feedback -->
            <Label fx:id="lblFeedback" styleClass="lbl-feedback" visible="false" managed="false" />
        </VBox>

        <Separator styleClass="module-divider" />

        <!-- ── Historial ── -->
        <VBox spacing="8" VBox.vgrow="ALWAYS">
            <Label text="Historial de frecuencia cardíaca" styleClass="section-title" />

            <TableView fx:id="tablaMetricas"
                       VBox.vgrow="ALWAYS"
                       styleClass="metrics-table">
                <placeholder>
                    <Label text="Aún no hay registros de frecuencia cardíaca."
                           styleClass="table-placeholder" />
                </placeholder>
                <columns>
                    <TableColumn fx:id="colFecha"         text="Fecha y hora"   prefWidth="220" />
                    <TableColumn fx:id="colBpm"           text="BPM"            prefWidth="110" />
                    <TableColumn fx:id="colAlerta"        text="Alerta"         prefWidth="110" />
                    <TableColumn fx:id="colRecomendacion" text="Recomendación"  prefWidth="320" />
                </columns>
            </TableView>
        </VBox>

    </VBox>
</AnchorPane>
