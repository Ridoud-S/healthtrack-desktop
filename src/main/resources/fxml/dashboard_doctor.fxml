<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.itc.healthtrack.controller.DoctorDashboardController"
      spacing="16"
      prefWidth="1000" prefHeight="680"
      style="-fx-padding: 32;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="lblWelcome"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnLogout" text="Cerrar sesión"
                onAction="#onLogoutPressed"/>
    </HBox>

    <Separator/>

    <!-- Contenido principal: dos columnas -->
    <HBox spacing="24" VBox.vgrow="ALWAYS">

        <!-- Columna izquierda: tabla de pacientes -->
        <VBox spacing="8" prefWidth="300">
            <Label text="Mis Pacientes"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <TableView fx:id="tablaPacientes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="160"/>
                    <TableColumn fx:id="colEmail"  text="Email"  prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Columna derecha: historial de métricas del paciente seleccionado -->
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label fx:id="lblPacienteSeleccionado"
                   text="Selecciona un paciente"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <TableView fx:id="tablaMetricas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colFecha"      text="Fecha y hora"  prefWidth="180"/>
                    <TableColumn fx:id="colTipo"       text="Tipo"          prefWidth="140"/>
                    <TableColumn fx:id="colSistolica"  text="Sistólica"     prefWidth="90"/>
                    <TableColumn fx:id="colDiastolica" text="Diastólica"    prefWidth="90"/>
                    <TableColumn fx:id="colAlerta"     text="Alerta"        prefWidth="80"/>
                    <TableColumn fx:id="colRecomendacion" text="Recomendación" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>

    </HBox>

</VBox>