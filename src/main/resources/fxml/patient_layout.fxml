<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.itc.healthtrack.controller.PatientLayoutController"
    prefWidth="1200"
    prefHeight="720"
    stylesheets="@../css/patient_layout.css">

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SIDEBAR IZQUIERDO                                  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="240" spacing="0">

            <!-- Logo / Nombre del sistema -->
            <VBox styleClass="sidebar-header" spacing="4">
                <Label text="HealthTrack" styleClass="app-logo" />
                <Label text="Portal del Paciente" styleClass="app-subtitle" />
            </VBox>

            <Separator styleClass="sidebar-divider" />

            <!-- Info del paciente activo -->
            <VBox styleClass="patient-info-card" spacing="2">
                <VBox.margin><Insets top="8" right="12" bottom="8" left="12"/></VBox.margin>
                <Label fx:id="labelPatientName" text="Cargando..." styleClass="patient-name" />
                <Label fx:id="labelPatientId"   text="ID: ---"    styleClass="patient-id"   />
            </VBox>

            <Separator styleClass="sidebar-divider" />

            <!-- ─── Sección: Módulos ─── -->
            <Label text="MODULOS" styleClass="sidebar-section-label">
                <VBox.margin><Insets top="12" left="16" bottom="4"/></VBox.margin>
            </Label>

            <Button fx:id="btnSummary"
                    text="Resumen General"
                    styleClass="nav-btn, nav-btn-active"
                    maxWidth="Infinity"
                    onAction="#handleSummary">
                <VBox.margin><Insets left="8" right="8" top="2" bottom="2"/></VBox.margin>
            </Button>

            <Button fx:id="btnBloodPressure"
                    text="Presion Arterial"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handleBloodPressure">
                <VBox.margin><Insets left="8" right="8" top="2" bottom="2"/></VBox.margin>
            </Button>

            <Button fx:id="btnGlucose"
                    text="Glucosa"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handleGlucose">
                <VBox.margin><Insets left="8" right="8" top="2" bottom="2"/></VBox.margin>
            </Button>

            <Button fx:id="btnHeartRate"
                    text="Frecuencia Cardiaca"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handleHeartRate">
                <VBox.margin><Insets left="8" right="8" top="2" bottom="2"/></VBox.margin>
            </Button>

            <Button fx:id="btnWeightBmi"
                    text="Peso / IMC"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handleWeightBmi">
                <VBox.margin><Insets left="8" right="8" top="2" bottom="2"/></VBox.margin>
            </Button>

            <Separator styleClass="sidebar-divider">
                <VBox.margin><Insets top="10" bottom="4"/></VBox.margin>
            </Separator>

            <!-- ─── Sección: Comunicación ─── -->
            <Label text="COMUNICACION" styleClass="sidebar-section-label">
                <VBox.margin><Insets top="4" left="16" bottom="4"/></VBox.margin>
            </Label>

            <Button fx:id="btnInbox"
                    text="Mensajes del Medico"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handleInbox">
                <VBox.margin><Insets left="8" right="8" top="2" bottom="2"/></VBox.margin>
            </Button>

            <!-- Spacer — empuja el botón de logout al fondo -->
            <Region VBox.vgrow="ALWAYS" />

            <Separator styleClass="sidebar-divider" />

            <Button fx:id="btnLogout"
                    text="Cerrar Sesion"
                    styleClass="nav-btn, nav-btn-danger"
                    maxWidth="Infinity"
                    onAction="#handleLogout">
                <VBox.margin><Insets top="4" bottom="16" left="8" right="8"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  ÁREA CENTRAL — aquí se inyectan los sub-módulos   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <center>
        <AnchorPane fx:id="contentArea" styleClass="content-area" />
    </center>

</BorderPane>
